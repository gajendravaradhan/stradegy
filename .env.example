# Stradegy Environment Configuration
# Copy this file to backend/.env and fill in your values

# Server
HOST=0.0.0.0
PORT=8420
DEBUG=false

# Alpaca Markets (required for trading)
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
PAPER_TRADING=true

# Discord (optional but recommended for alerts)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_USER_ID=your_discord_user_id
DISCORD_GENERAL_CHANNEL_ID=your_general_channel_id

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Finnhub (required for news sentiment and data)
FINNHUB_API_KEY=your_finnhub_key

# Reddit (optional — uses public JSON if empty)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=stradegy/1.0

# Autonomy (semi or full)
AUTONOMY_MODE=semi

# Risk Parameters
MAX_DRAWDOWN=0.20
RISK_PER_TRADE=0.03
MAX_POSITIONS=1
STOP_ATR_MULT=1.5
TAX_RATE_SHORT_TERM=0.30
TAX_RATE_LONG_TERM=0.15

# Paths (relative to working directory)
DATA_DIR=data
CONFIG_DIR=config
EVAL_DIR=eval
STRATEGIES_DIR=strategies

# Database
DATABASE_URL=sqlite+aiosqlite:///data/stradegy.db
